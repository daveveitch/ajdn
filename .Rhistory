library(quantmod)
start_date='2021-01-01'
end_date='2022-12-31'
# FAANG stocks
stocks_vec=c('META','AMZN','AAPL','NFLX','GOOG')
stocks_list=list()
# Get SPY so we can adjust prices
getSymbols('QQQ', from = start_date,
to = end_date,warnings = FALSE,
auto.assign = TRUE)
QQQ_adjusted=QQQ$QQQ.Adjusted
QQQ_matrix=matrix(QQQ_adjusted,nrow=1)
rownames(QQQ_matrix)=c('QQQ')
colnames(QQQ_matrix)=as.character(index(QQQ))
for(i in 1:length(stocks_vec)){
temp_dat=new.env()
getSymbols(stocks_vec[i], from = start_date,
to = end_date,warnings = FALSE,
auto.assign = TRUE,env=temp_dat)
stocks_list[[stocks_vec[i]]]=get(stocks_vec[i],envir=temp_dat)
}
QQQ_adjusted
