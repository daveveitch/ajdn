  setwd(paste(results_dir,'/type_1',sep=''))

  experiment_df=read.csv('experiment_df.csv')
  experiment_df$type1=999
  
  for(i in 1:nrow(experiment_df)){
    sim_results=read.csv(paste('type_1-',sprintf("%03d",i),'.csv',sep=''))
    
    # slightly different format for type1 of PLS/PLST
