                                     compute_times[1]=(end_time-start_time)[3]+thresh_compute_time 
                                     
                                   }else if(cp_method=='DBLCUSUM'){
                                     start_time=proc.time()
                                     dblcusum_cp_located = dcbs.alg(x_matrix,
                                                                    cp.type=1,     # look for CP in mean
                                                                    phi=-1,        # section 4.1 of paper
                                                                    # phi=0 good for sparse cp
                                                                    # phi=.5 optimal in certain scenario
                                                                    temporal=TRUE, # use LR variance to normalize
                                                                    q=alpha,       # quantile of bootstrap to use as threshold 
                                                                    B=B,           # number of bootstraps to use
                                                                    do.parallel = 0)           
                                     dblcusum_cp_located = as.numeric(dblcusum_cp_located$ecp)
                                     end_time=proc.time()  
                                     compute_times[2]=(end_time-start_time)[3]
                                   }else if(cp_method=='AJDN'){
                                     start_time=proc.time()
                                     ajdn_cp_located=ajdn_detect_jumps(x_matrix,s,s_prime,B,alpha)
                                     end_time=proc.time()
                                     compute_times[4]=(end_time-start_time)[3]
                                   }else if(cp_method=='LOCLIN'){
                                     start_time=proc.time()
                                     
                                     # Here we need to break up the time series so that this runs in an adequate
                                     # amount of time, here we will target the size of p*(n/M)~2500, which will
                                     # take this about 1 minute to compute
                                     # Note that in some simulations this M led to problems (I believe linked to too many)
                                     # eigenvalues being close to 0 of the Q matrix, therefore will try this M and if it doesn't
                                     # work will try a different M with more observations per block
                                     M=round(p*n/loclin_M_div)
                                     
                                     loclin_cp_located=try(loclin_cp(x_matrix,auto_bandwidth,sd_interval,alpha,loclin_bootstraps,M),silent=TRUE) 
                                     
                                     if(class(loclin_cp_located)[1]=='try-error'){
                                       loclin_cp_located='ERROR'  
                                     }
                                     end_time=proc.time()
                                     
                                     compute_times[3]=(end_time-start_time)[3]
                                   }
                                   
                                   changepoints_by_method_list=list(sparse_cp_located,
                                                                    dblcusum_cp_located,
                                                                    loclin_cp_located,
                                                                    ajdn_cp_located)
                                   
                                   results_df=evaluate_changepoints_compare(true_changepoint_locations,
                                                                            margin_of_error,
                                                                            results_df,
                                                                            changepoints_by_method_list,
                                                                            cp_scenario,
                                                                            n,K,signal_to_noise,
                                                                            gamma)
                                   
                                   print(paste(cp_method,i))
                                   print(Sys.time())
                                   results_df$compute_time=compute_times
                                   results_df=results_df[cp_method_i,]
                                   
                                   if(cp_method_i==1){
                                     cp_clean=paste(sparse_cp_located,collapse='-')
                                   }else if(cp_method_i==2){
                                     cp_clean=paste(dblcusum_cp_located,collapse='-')
                                   }else if(cp_method_i==3){
                                     cp_clean=paste(loclin_cp_located,collapse='-')
                                   }else if(cp_method_i==4){
                                     cp_clean=paste(unique(ajdn_cp_located$t_index),collapse='-')
                                   }
                                   results_df$cp_clean=cp_clean
                                   
                                   results_df
                                 }
      
      parallel::stopCluster(cl)
      
      setwd(file.path(results_dir,function_name))
      if(!file.exists('longformresults')){
        dir.create(file.path(results_dir,function_name,'longformresults'))
      }  
      
      setwd(file.path(results_dir,function_name,'longformresults'))
      write.csv(simulation_results,paste(sprintf("%03d",experiment_number),cp_method,'-longformresults.csv',sep=''))
      
    }
    
  }
  
}

compare_methods_summarize_results<-function(job_num,results_dir,working_dir,latex_fig_dir){
  function_name='compare_methods_power'
  setwd(file.path(results_dir,function_name))
  K=500
  experiment_df=read.csv(paste(function_name,'-experiment_df.csv',sep=''))
  
  if(!file.exists('summarized_results')){
    dir.create(file.path(results_dir,function_name,'summarized_results'))
  }
  
  if(job_num==999){
    summ_to_run = 1:nrow(experiment_df)
  }else{
    summ_to_run = job_num
  }
  
  for(i in summ_to_run){
    sim_setting=experiment_df[i,]
    results_df=data.frame(n=sim_setting$n,p=sim_setting$p,gamma=sim_setting$gamma,cp_scenario=sim_setting$cp_scenario,
                          dgp=sim_setting$dgp,cp_method=c('INSPECT','DBLCUSUM','LOCLIN','AJDN'),
                          m=-1,m_p=-1,MAD=-1,T=-1)
    
    for(cp_method in c('INSPECT','DBLCUSUM','LOCLIN','AJDN')){
      setwd(file.path(results_dir,function_name,'longformresults'))
      sim_results=read.csv(paste(sprintf("%03d",i),cp_method,'-longformresults.csv',sep=''))[1:K,]
      results_df[results_df$cp_method==cp_method,'m']=mean(sim_results$cp_found)
      results_df[results_df$cp_method==cp_method,'m_p']=mean(sim_results$perfect)
      results_df[results_df$cp_method==cp_method,'MAD']=mean(sim_results[sim_results$MAD!=999,'MAD'])
      results_df[results_df$cp_method==cp_method,'T']=mean(sim_results$compute_time)
    }
    
    results_df[,'m']=sprintf("%.3f", results_df[,c('m')])
    results_df[,'m_p']=sprintf("%.3f", results_df[,c('m_p')])
    results_df[,'MAD']=sprintf("%.3f", results_df[,c('MAD')])
    results_df[,'T']=round(results_df$T)
    
    results_df=t(results_df)
    
    setwd(file.path(results_dir,function_name,'summarized_results'))
    write.csv(results_df,file=paste('summarized_results-',sprintf("%03d", i),'.csv',sep=''))
  }
  
}

