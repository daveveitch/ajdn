  mini_file_list=file_list[-1]                 # remove maps
  mini_file_list_df=data.frame(matrix(ncol=6,nrow=length(mini_file_list)))
  start_time_vec=rep(0,nrow(mini_file_list_df))
  end_time_vec=rep(0,nrow(mini_file_list_df))

  for(i in 1:nrow(mini_file_list_df)){
    mini_file=readMiniseedFile(mini_file_list[i])

    mini_file_list_df[i,1]=mini_file@traces[[1]]@stats@station
    mini_file_list_df[i,2]=length(mini_file@traces)         # number of traces
    mini_file_list_df[i,3]=max(getGaps(mini_file)$gaps)     # duration in seconds of gaps
    mini_file_list_df[i,4]=length(mini_file@traces)         # number of traces
    start_time_vec[i]=as.character(mini_file@requestedStarttime)
    end_time_vec[i]=as.character(mini_file@requestedEndtime)

    print(i)
  }

  mini_file_list_df[,5]=start_time_vec
  mini_file_list_df[,6]=end_time_vec
  mini_file_list_df[,7]=mini_file_list
  mini_file_list_df=mini_file_list_df[-nrow(mini_file_list_df),]

  setwd(paste(real_data_dir,'/turkey',sep=''))
  
  write.csv(mini_file_list_df,file='mini_file_info.csv')

  setwd(paste(real_data_dir,'/turkey',sep=''))
  mini_file_list_df=read.csv('mini_file_info.csv')[,-c(1,3)]
  colnames(mini_file_list_df)=c('station','maxgapseconds','numtraces','starttime','endtime','filename')
  
  # Read list of metadata about stations
  station_metadata_raw=readLines('gmap-stations.txt')
  station_metadata=data.frame(matrix(ncol=4,nrow=length(station_metadata_raw)-3))  
  
  for(i in 4:length(station_metadata_raw)){
    station_info=strsplit(station_metadata_raw[i],split='\\|')
    station_metadata[i-3,1]=station_info[[1]][2] # name
    station_metadata[i-3,2]=station_info[[1]][3] # lat
    station_metadata[i-3,3]=station_info[[1]][4] # long
    station_metadata[i-3,4]=station_info[[1]][6] # name
  }
  
  colnames(station_metadata)=c('station','latitude','longitude','location')
  
  # Here choose 7 traces, 15 sec gap
  
  filtered_mini_file_list=mini_file_list_df[as.POSIXct(mini_file_list_df$starttime,tz='UTC')<=as.POSIXct('2023-02-05 20:00:00',tz='UTC'),]
  filtered_mini_file_list=filtered_mini_file_list[as.POSIXct(filtered_mini_file_list$endtime,tz='UTC')>=as.POSIXct('2023-02-06 14:00:00',tz='UTC'),]
  filtered_mini_file_list=mini_file_list_df[((mini_file_list_df$numtraces<=7)&
                                               (mini_file_list_df$maxgapseconds<=15)),]
  station_numbers=as.numeric(rownames(filtered_mini_file_list))
  filtered_station_metadata=station_metadata[station_numbers,]
  
  # add in location data
  filtered_mini_file_list$latitude=999
  filtered_mini_file_list$longitude=999
  filtered_mini_file_list$location='a'
  
  for(i in 1:nrow(filtered_mini_file_list)){
    station_name=filtered_mini_file_list$station[i]
    filtered_mini_file_list[filtered_mini_file_list$station==station_name,'latitude']=station_metadata[station_metadata$station==station_name,'latitude']
    filtered_mini_file_list[filtered_mini_file_list$station==station_name,'longitude']=station_metadata[station_metadata$station==station_name,'longitude']
    filtered_mini_file_list[filtered_mini_file_list$station==station_name,'location']=station_metadata[station_metadata$station==station_name,'location']
  }
  
  setwd(paste(real_data_dir,'/turkey/mseedfiles',sep=''))  
  
  x_matrix=matrix(nrow=nrow(filtered_mini_file_list),
                  ncol=as.numeric(difftime(target_end_time,target_start_time,units='secs'))/(one_datapoint_x_seconds))
  
  for(i in 1:nrow(filtered_mini_file_list)){
    # Merge traces together into one
    single_trace=readMiniseedFile(filtered_mini_file_list$filename[i]) # 4 traces
    single_trace_merged=try(mergeTraces(single_trace,fillMethod='fillNA')) # 1 trace
    if(typeof(single_trace_merged)=='character'){
      # do nothing
    }else{
      start_time=single_trace_merged@traces[[1]]@stats@starttime
      end_time=single_trace_merged@traces[[1]]@stats@endtime
      sample_per_sec=single_trace_merged@traces[[1]]@stats@sampling_rate
      
      # number of time points to cut from start/end
      start_cutoff=as.numeric(difftime(target_start_time,start_time,units='secs'))*100
      end_cutoff=as.numeric(difftime(end_time,target_end_time,units='secs'))*100
      
      # The lengths can slightly differ, although it seems at most by like 1/2 a second, so don't worry
      # too much about that
      raw_length=length(single_trace_merged@traces[[1]]@data)
      righttime_trace=single_trace_merged@traces[[1]]@data[(start_cutoff+1):(raw_length-end_cutoff)]
      print(paste('length righttime trace',length(righttime_trace)))
      downsampled_trace=righttime_trace[seq(1,length(righttime_trace),length.out=ncol(x_matrix))]
      
      # Centre based on first 1000 values
      centred_trace=downsampled_trace-mean(downsampled_trace[!is.na(downsampled_trace)])
      
      transformed_trace=log(abs(centred_trace))
      print(paste('NAs',sum(is.na(transformed_trace))))
      
      x_matrix[i,]=transformed_trace
      
      print(i)  
    } 
  }
  
  # Rows where there was an error filling them, delete them and
  # record which rows we still have
  bad_rows=c()
  for(i in 1:nrow(x_matrix)){
    if(sum(is.na(x_matrix[i,]))==ncol(x_matrix)){
      bad_rows=c(bad_rows,i)
    }
  }
  
  x_matrix=x_matrix[-bad_rows,]
  good_filtered_mini_file_list=filtered_mini_file_list[-bad_rows,]
  
  setwd(paste(real_data_dir,'/turkey',sep=''))
  
  
  # Fill NA with last available datapoint
  for(i in 1:nrow(x_matrix)){
    for(j in 1:ncol(x_matrix)){
      if(is.na(x_matrix[i,j])){x_matrix[i,j]=x_matrix[i,j-1]}
    }
  }
  
  orig_x_matrix=x_matrix
  
  # Bad rows by visual inspection
  new_bad_rows=c(35,33,28,15,10,8,6,2,31,4) #31,4
  
  x_matrix=x_matrix[-new_bad_rows,]
  good_filtered_mini_file_list=good_filtered_mini_file_list[-new_bad_rows,]
  
  write.csv(good_filtered_mini_file_list,'good_meta.csv')
  write.csv(x_matrix,file='earthquake_data.csv')
  
}

# Selection of hyperparameters for Turkey analysis and
# final detection of changepoints
# Runtime details - MERCURY 70 cores, 7 hours
turkey_analysis<-function(job_num,results_dir,working_dir,latex_fig_dir){
  setwd(working_dir)
  source("AJDNHelperFunctions.R")
  
  # Set this to limit number of threads used in parallelization
  Sys.setenv(OMP_NUM_THREADS = 1,MKL_NUM_THREADS=1,BLAS_NUM_THREADS=1,LAPACK_NUM_THREDS=1)
  
  B=500                        # 500
  alpha=.05
  scale_to_test_number=100      # 100 - total number of scales to test for both low_s,high_s (except when high_s is smaller than ROT)
  
  setwd(paste(real_data_dir,'/turkey',sep=''))
  x_matrix=read.csv('earthquake_data.csv')[,-1]
  sensor_data=read.csv('good_meta.csv')
  n=dim(x_matrix)[2]
  p=dim(x_matrix)[1]
  
  pilot_s=scales_rot(n,p)
  rot_ratio=pilot_s[1]/pilot_s[2]
  
  scale_to_test_range=(pilot_s[2]-pilot_s[1])     # will test scales +- range around rule of thumbs, and +60/2070 from minimum scale
  
  max_s_prime=round(n**(1/3))
  
  high_scales=seq(pilot_s[2]-scale_to_test_range,pilot_s[2]+scale_to_test_range,length.out=scale_to_test_number)
  low_scales=high_scales*rot_ratio
  
  experiment_df=expand.grid(high_scales,0,c(1,2,3,4,5,10,18)) # 18 rule of thumb max
  colnames(experiment_df)=c('high_scale','low_scale','ns_prime')
  experiment_df$low_scale=experiment_df$high_scale*rot_ratio

  # Representative segments to use in selection of s'
  # if you look at ACF, its clear there is no time dependence
  # Istanbul is dimension 20
  # appears between 2000 and 4000 no jumps
  segment_indexes=list(c(2000,4000)) # 2000,4000

  print('Calculating ideal S Primes')
  desired_bias=calc_desired_lrv_ratio(n)
  s_prime_ideal=rep(0,p)

  for(segment_dimension in 1:p){
    s_prime_unrounded=rep(0,length(segment_indexes))  
    
    for(j in 1:length(segment_indexes)){
      # Remove smooth trend
      n_segment=segment_indexes[[j]][2]-segment_indexes[[j]][1]+1 # total length of segment
      
      x=seq(1,n_segment)
      y=as.numeric(x_matrix[segment_dimension,segment_indexes[[j]][1]:segment_indexes[[j]][2]])
      
      auto_bandwidth=dpill(x,y)
      np_mean_est=locpoly(x,y,bandwidth = auto_bandwidth,gridsize=length(x))$y
      
      estimated_errors=as.numeric(y-np_mean_est)
      
      acf_estimate=acf(estimated_errors,type='covariance',lag.max=max_s_prime-1,plot=FALSE)$acf[,,1]
      s_prime_list=seq(1,max_s_prime)
      th_div_bs_LRV_vec=rep(0,length(s_prime_list))
      empirical_LRV=acf_estimate[1]+2*sum(acf_estimate[2:(max_s_prime)])
      
      for(i in 1:length(s_prime_list)){
        s_prime=s_prime_list[i]
        bootstrap_LRV=bootstrap_lrv(s_prime,acf_estimate)
        th_div_bs_LRV_vec[i]=empirical_LRV/bootstrap_LRV
      }
      
      s_prime_unrounded[j]=s_prime_list[which.min(abs(th_div_bs_LRV_vec-desired_bias))]
      
    }
    
    # Choose most conservative s_prime (largest)
    s_prime=round(mean(s_prime_unrounded))/n
    s_prime_ideal[segment_dimension]=s_prime*n
  }
  
  print(paste('Median value of s_prime',median(s_prime_ideal)))
  
  # Setup MV Analysis
  cl <- parallel::makeCluster(ncores,outfile="")
  doParallel::registerDoParallel(cl)
  
  print(paste('Total Experiments',nrow(experiment_df)))
  
  if(job_num==999){
    sims_to_run = 1:nrow(experiment_df)
  }else{
    sims_to_run = job_num
  }
  
  experiment_results=foreach(i=sims_to_run, .combine='rbind',
                             .packages = c('Matrix','MASS','plyr','KernSmooth'))%dopar%{
                               
                               # Load functions
                               setwd(working_dir)
                               source('AJDNHelperFunctions.R')
                               
                               set.seed(i)
                               
                               s_prime=experiment_df[i,'ns_prime']/n
                               low_scale=experiment_df[i,'low_scale']
                               high_scale=experiment_df[i,'high_scale']
                               s=sparsify_scales(low_scale,high_scale,n,p)
                               
                               cps_detected=ajdn_detect_jumps(x_matrix,s,s_prime,B,alpha,
                                                                     loud=TRUE)
                               
                               bic_sum=0
                               
                               for(j in 1:p){
                                 bic_sum=bic_sum+calc_bic(x_matrix[j,],
                                                            cps_detected[cps_detected$dim==j,],
                                                            s_prime)
                               }
                               
                               setwd(file.path(results_dir, 'turkey_analysis'))
                               
                               bic_df=data.frame(bic=bic_sum,
                                                 cps=nrow(cps_detected))
                               write.csv(bic_df,file=paste('turkey_analysis_bic-',sprintf("%04d", i),'.csv',sep=''))
                               write.csv(cps_detected,file=paste('turkey_analysis_cps-',sprintf("%04d", i),'.csv',sep=''))
                               
                               
                               print(i)
                               c(bic_sum,nrow(cps_detected))
                             }
  
  parallel::stopCluster(cl)
  
  if(length(sims_to_run)>1){
    setwd(real_data_dir)
    experiment_df$bic=experiment_results[,1]
    experiment_df$cps=experiment_results[,2]
    
    setwd(file.path(results_dir, 'turkey_analysis'))
    write.csv(experiment_df,file='turkey_analysis_bic.csv')
    
    # Determine which has lowest BIC
    experiment_df=experiment_df[which(experiment_df$bic==min(experiment_df$bic)),]
    experiment_df=experiment_df[which.min(experiment_df$low_scale+experiment_df$high_scale),]
    
    s_low=experiment_df$low_scale[1]
    s_high=experiment_df$high_scale[1]
    s=sparsify_scales(s_low,s_high,n,p)
    s_prime=experiment_df[1,'ns_prime']/n
    
    print('Detecting CPs with New Scales')
    set.seed(as.numeric(rownames(experiment_df)[1]))
    cps_detected=ajdn_detect_jumps(x_matrix,s,s_prime,B,alpha,loud=TRUE)
    
    write.csv(cps_detected,file='turkey_analysis_cps.csv')
    
    # midcheck
    setwd(file.path(results_dir, 'turkey_analysis'))
    a=list.files() 
    exper_bic=rep(0,200)
    
    for(i in 2:201){
      result=read.csv(a[i])
      exper_bic[i-1]=result$bic
    }  
  }
  
}

