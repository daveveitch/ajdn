  CUSUM_calc<-function(data_ts){
    # This function calculates the CUSUM statistics from a time series
    # INPUT
    # data_ts            - a time series
    # OUTPUT
    # CUSUM_list         - [[1]] a vector of S_j values
    #                      [[2]] S_n
    #                      [[3]] T_n
    
    n=length(data_ts)
    
    CUSUM_list=list()
    
    CUSUM_vector=rep(0,n)
    CUSUM_vector[1]=data_ts[1]
    
    for(i in 2:n){
      CUSUM_vector[i]=CUSUM_vector[i-1]+data_ts[i]
    }
    
    S_n=CUSUM_vector[n]
    
    CUSUM_vector=CUSUM_vector-(seq(1,n)/n)*CUSUM_vector[n]
    
    T_n=max(abs(CUSUM_vector))
    
    CUSUM_list[[1]]=CUSUM_vector
    CUSUM_list[[2]]=S_n
    CUSUM_list[[3]]=T_n
    
    return(CUSUM_list)
  }
  
  
  CUSUM_mv<-function(data_ts,S_n,m_vector,mv_window){
    # This function calculates the MV window size for the robust
    # structural change test procedure
    # INPUTS
    # data_ts        - time series
    # S_n            - precalculated value of S_n
    # m_vector       - vector of m to test
    # mv_window      - how wide window should be in calculation of standard error
    # OUTPUTS
    # m              - bootstrap size
    
    # Createa  matrix which will have gamma_hat(r/n,r/n) for different
    # values of m
    n=length(data_ts)
    
    gamma_hat_matrix=matrix(data=NA,nrow=length(m_vector),ncol=n)
    
    for(m_index in 1:length(m_vector)){
      m=m_vector[m_index]
      
      S_j_m_vector=rep(0,n-m+1)
      
      # Calculate S_j_m vector
      for(j in 1:(n-m+1)){
        S_j_m_vector[j]=sum(data_ts[j:(j+m-1)])    
      }
      
      gamma_hat_matrix[m_index,m]=sum((S_j_m_vector[1:m]-(m/n)*S_n)**2)/(m*(n-m+1))
      
      for(r in (m+1):(n-m+1)){
        gamma_hat_matrix[m_index,r]=gamma_hat_matrix[m_index,r-1]+(S_j_m_vector[r]-(m/n)*S_n)**2/(m*(n-m+1))  
      }
    }
    
    # Cacluate SE
    mv_matrix=matrix(data=0,nrow=length(m_vector),ncol=n)
    
    for(m_index in 1:length(m_vector)){
      m=m_vector[m_index]
      
      # window of m values we are looking at
      m_window_indexes=(abs(m_vector-m))<=mv_window
      m_window=m_vector[m_window_indexes]
      
      for(r in max(m_vector):(n-max(m_vector))){
        gamma_bar_r=mean(gamma_hat_matrix[m_window_indexes,r])  
        gamma_se=sqrt((1/length(m_window))*sum((gamma_hat_matrix[m_window_indexes,r]-gamma_bar_r)**2))
        mv_matrix[m_index,r]=gamma_se
      }
    }
    
    max_stats=apply(mv_matrix,MARGIN=1,FUN=max)
    
    return(m_vector[which.min(max_stats)])
  }
  
  CUSUM_bootstraps<-function(data_ts,B,m,S_n,initial_seed){
    # This function conducts the bootstrap procedure for calculating
    # the critical values of the test statistic
    # INPUT
    # data_ts                - time series
    # B                      - number of bootstraps
    # m                      - bootstrap window size
    # S_n                    - S_n from the CUSUM statistic
    # initial_seed           - seed for the bootstrap
    
    n=length(data_ts)
    
    S_j_m_vector=rep(0,n-m+1)
    
    # Calculate S_j_m vector
    for(j in 1:(n-m+1)){
      S_j_m_vector[j]=sum(data_ts[j:(j+m-1)])    
    }
    
    # Conduct the bootstrap
    set.seed(initial_seed)
    bootstrap_values=rep(0,B)
    
    for(b in 1:B){
      bootstrap_normals=rnorm(n)
      
      phi_m=rep(0,n)
      
      phi_m[1]=(1/sqrt(m*(n-m+1)))*(S_j_m_vector[1]-(m/n)*S_n)*bootstrap_normals[1]
      
      for(i in 2:(n-m+1)){
        phi_m[i]=phi_m[i-1]+(1/sqrt(m*(n-m+1)))*(S_j_m_vector[i]-(m/n)*S_n)*bootstrap_normals[i]
      }
      
      bootstrap_stat=phi_m-seq(1,n)/(n-m+1)*phi_m[n-m+1]
      bootstrap_stat=max(abs(bootstrap_stat[(m+1):(n-m+1)]))
      bootstrap_values[b]=bootstrap_stat
    }
    
    return(bootstrap_values)
    
  }
  
