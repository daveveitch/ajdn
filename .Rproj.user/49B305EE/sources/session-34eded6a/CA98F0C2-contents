# Selecting hyperparameters for stocks dataset and then
# running a final analysis
# Runtime details - MERCURY ~1min
stocks_analysis<-function(job_num,results_dir,working_dir,latex_fig_dir){
  setwd(working_dir)
  source("AJDNHelperFunctions.R")
  
  # Set this to limit number of threads used in parallelization
  Sys.setenv(OMP_NUM_THREADS = 1,MKL_NUM_THREADS=1,BLAS_NUM_THREADS=1,LAPACK_NUM_THREDS=1)
  
  alpha=.05
  B=500
  scale_to_test_number=100    # number of scales to test for each s_prime
  
  setwd(paste(real_data_dir,'/stocks',sep=''))
  stocks_data=as.matrix(read.csv('stocks_data.csv',row.names = 1))

  set.seed(1)
  
  p=nrow(stocks_data)
  n=ncol(stocks_data)
  
  max_s_prime=round(n**(-2/3)*n)
  
  rot_s=scales_rot(n,p)
  rot_ratio=rot_s[1]/rot_s[2]
  rot_scale_range=rot_s[2]-rot_s[1]
  
  # Roughly half a quarter
  potential_s_high=seq((1/16-rot_scale_range/2),1/16+rot_scale_range/2,length.out=scale_to_test_number)
  
  bic_experiment_df=expand.grid(s_prime=1:max_s_prime,
                                s_high=potential_s_high)
  
  setwd(working_dir)
  
  print('Running BIC')
  
  # Setup MV Analysis
  cl <- parallel::makeCluster(ncores,outfile="")
  doParallel::registerDoParallel(cl)  
  
  print(paste('Total Experiments',nrow(bic_experiment_df)))
  
  experiment_results=foreach(i=1:nrow(bic_experiment_df), .combine='rbind',
                             .packages = c('Matrix','MASS','plyr','KernSmooth'))%dopar%{
                               
                               # Load functions
                               setwd(working_dir)
                               source('AJDNHelperFunctions.R')
                               
                               set.seed(i)
                               
                               s_prime=bic_experiment_df[i,'s_prime']/n
                               s_high=bic_experiment_df[i,'s_high']
                               s_low=s_high*rot_ratio
                               s=sparsify_scales(s_low,s_high,n,p)
                               
                               cps_detected=ajdn_detect_jumps(stocks_data,s,s_prime,B,alpha)
                               
                               bic_sum=0
                               for(j in 1:p){
                                 bic_sum=bic_sum+calc_bic(stocks_data[j,],
                                                            cps_detected[cps_detected$dim==j,],
                                                            s_prime)
                               }
                               
                               setwd(file.path(results_dir, 'stocks_analysis'))
                               
                               bic_df=data.frame(bic=bic_sum,
                                                 cps=nrow(cps_detected))
                               write.csv(bic_df,file=paste('stocks_analysis_bic-',sprintf("%04d", i),'.csv',sep=''))
                               write.csv(cps_detected,file=paste('stocks_analysis_cps-',sprintf("%04d", i),'.csv',sep=''))
                               
                               print(i)
                               c(bic_sum,nrow(cps_detected))
                               
                             }
  
  parallel::stopCluster(cl)
  
  setwd(results_dir)
  bic_experiment_df$bic=experiment_results[,1]
  bic_experiment_df$cps=experiment_results[,2]
  
  setwd(file.path(results_dir,'stocks_analysis'))
  write.csv(bic_experiment_df,file='stocks_bic.csv')  
  
  # Determine which has lowest BIC
  low_experiment=which(bic_experiment_df$bic==min(bic_experiment_df$bic))
  bic_experiment_df=bic_experiment_df[low_experiment,]
  bic_experiment_df=bic_experiment_df[which.min((1+rot_ratio)*bic_experiment_df$s_high),]
  bic_experiment_df=bic_experiment_df[which.min(bic_experiment_df$s_prime),]
  
  s_high=bic_experiment_df$s_high[1]
  s_low=s_high*rot_ratio
  s_prime=bic_experiment_df$s_prime[1]/n
  s=sparsify_scales(s_low,s_high,n,p)
  
  print('Detecting CPs with New Scales')
  set.seed(low_experiment)
  cps_detected=ajdn_detect_jumps(stocks_data,s,s_prime,B,alpha,loud=TRUE)
  
  write.csv(cps_detected,file='stocks_cps.csv')
  
}

