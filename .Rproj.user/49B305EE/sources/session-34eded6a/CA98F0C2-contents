      experiment_df[i,'type1']=sim_results$type1
    }else{
      experiment_df[i,'type1']=mean(sim_results$V1)
    }
    
  }
  
  experiment_df=experiment_df[,c(-1,-5)]
  
  sim_results_tab=reshape(experiment_df, idvar = c('dgp','p'), timevar = "n", direction = "wide")
  
  new_results_tab=cbind(sim_results_tab[1:10,1:6],sim_results_tab[11:20,2:6])
  
  new_results_tab=new_results_tab[,c(1,7,11:8,2,6:3)]
  
  
  colnames(new_results_tab)=c('DGP','p','n=500','n=1000','n=2000','n=3000',
                              'p','n=500','n=1000','n=2000','n=3000')
  
  print(xtable(new_results_tab, caption = "Type I errors produced by AJDN across different data generating processes, $n$ and $p$ where $\alpha=0.05$.",
