type_1<-function(job_num,results_dir,working_dir,latex_fig_dir){
  print(working_dir)
  setwd(working_dir)
  source("AJDNHelperFunctions.R")
  function_name='type_1'
  
  # Set this to limit number of threads used in parallelization
  Sys.setenv(OMP_NUM_THREADS = 1,MKL_NUM_THREADS=1,BLAS_NUM_THREADS=1,LAPACK_NUM_THREDS=1)
  
  B=1000              # 1000
  K_total=1000        # 1000
  K_per_core=1        # 1
  alpha=.05
  
  n_vector=c(3000,2000,1000,500)   #  c(3000,2000,1000,500)
  p_vector=c(100,10)               #  c(100,10)
  dgp_vector=c('IID','IIDT','GS','GST','PS','PST','LS','LST','PLS','PLST')
  
  # Create dataframe
  experiment_df=expand.grid(dgp=dgp_vector,p=p_vector,n=n_vector,
                            stringsAsFactors = FALSE)
  experiment_df$experiment_number=1:nrow(experiment_df)
  
  experiment_df$type1=999
  
  setwd(results_dir)
  if(!file.exists(function_name)){
    dir.create(file.path(results_dir,function_name))
  }
  setwd(file.path(results_dir,function_name))
  write.csv(experiment_df,file='experiment_df.csv')  
  
  # Determine which row of lrv_df to analyze
  if(job_num==999){
    # Do nothing, run over the whole of lrv_df
  }else if(job_num==997){
    experiment_df=experiment_df[experiment_df$dgp%in%c('PLS','PLST'),] 
  }else{
    # only look at the lrv_df with the job_num you want
    experiment_df=experiment_df[job_num,]
  }
  
  setwd(working_dir)
  for(x in nrow(experiment_df):1){
    # Determine which s to begin with
    p=experiment_df[x,'p']
    n=experiment_df[x,'n']
    dgp=experiment_df[x,'dgp']
    adjust_seed=experiment_df[x,'adjust_seed']
    experiment_number=experiment_df[x,'experiment_number']
    
    s_prime=s_prime_select(dgp,n,p)
    s=scales_rot(n,p)
    s=sparsify_scales(s[1],s[2],n,p)
    
    setwd(working_dir)
    
    cl <- parallel::makeCluster(ncores,outfile="")
    doParallel::registerDoParallel(cl)  
    
    experiment_results=foreach(i=1:(K_total/K_per_core), 
                               .combine = 'rbind',
                               .packages = c('Matrix','MASS','plyr'))%dopar%{
                                 
                                 # Load functions
                                 source('AJDNHelperFunctions.R')
                                 
                                 type_1_results=rep(0,K_per_core)
                                 
                                 for(k in 1:K_per_core){
                                   set.seed(1000*p+1000*n+K_per_core*(i-1)+k+strtoi(dgp,36L)+1000)
                                   x_matrix = generate_x_matrix(n,p,dgp,s)
                                   cps_detected=ajdn_detect_jumps(x_matrix,s,s_prime,B,alpha)
                                   if(dim(cps_detected)[1]>0){type_1_results[k]=1}
                                 }
                                 
                                 print(paste(experiment_number,i,Sys.time()))
                                 c(sum(type_1_results)/K_per_core)
                               }
    
    print(paste(experiment_number,n,p,dgp,Sys.time(),mean(experiment_results[,1])))
    parallel::stopCluster(cl)
    
    setwd(file.path(results_dir,function_name))
    filename=paste(function_name,'-',sprintf("%03d",experiment_number),'.csv',sep='')
    write.csv(experiment_results,file=filename)  

  }  
  
}

type_1_table<-function(job_num,results_dir,working_dir,latex_fig_dir){
  library(data.table)
  
