compare_methods_power<-function(job_num,results_dir,working_dir,latex_fig_dir){
  setwd(working_dir)
  source('AJDNHelperFunctions.R')
  function_name='compare_methods_power'
  
  # Set this to limit number of threads used in parallelization
  Sys.setenv(OMP_NUM_THREADS = 1,MKL_NUM_THREADS=1,BLAS_NUM_THREADS=1,LAPACK_NUM_THREDS=1)
  
  B=500             # 500
  K=500             # 500
  error_K=20        # 20 - extra K to run in case of errors
  alpha=.05
  
  xi_iter=1000             # for inspect method
  sd_interval=c(-500,500)  # for loclin method
  loclin_bootstraps=200
  loclin_M_div=1000
  ignore_methods=c()       # here write 'sparse','dblcusum','ajdn','loclin'
  # depending on which methods you do not wish to run
  
  n_vector=c(1000)                #  c(3000,2000,1000,500)
  p_vector=c(10,100)              #  c(10,100)
  
  # Create dataframe scenario 1
  dgp_vector=c('IID','IIDT','LS','LST','GS','PS','PLS','GST','PST','PLST')
  gamma_vector=c('a','b','c')
  snr_vector=c(2,5)
  experiment_df_1=expand.grid(dgp=dgp_vector,p=p_vector,n=n_vector,gamma=gamma_vector,
                              snr=snr_vector,cp_scenario=1,
                              stringsAsFactors = FALSE)
  experiment_df_1=experiment_df_1[order(experiment_df_1$n*experiment_df_1$p),]
  experiment_df_1[experiment_df_1$gamma=='a','gamma']=2/experiment_df_1[experiment_df_1$gamma=='a','p']
  experiment_df_1[experiment_df_1$gamma=='b','gamma']=1/sqrt(experiment_df_1[experiment_df_1$gamma=='b','p'])
  experiment_df_1[experiment_df_1$gamma=='c','gamma']=1
  
  # create dataframe scenario 2
  dgp_vector=c('IID','IIDT','LS','LST','GS','PS','PLS','GST','PST','PLST')
