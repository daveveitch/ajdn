        floating = TRUE, latex.environments = "center",table.placement = 'H',
        include.rownames=FALSE,scalebox=1)
  
}


compare_methods_type_1<-function(job_num,results_dir,working_dir,latex_fig_dir){
  setwd(working_dir)
  source('AJDNHelperFunctions.R')
  function_name='compare_methods_type_1'
  
  # Set this to limit number of threads used in parallelization
  Sys.setenv(OMP_NUM_THREADS = 1,MKL_NUM_THREADS=1,BLAS_NUM_THREADS=1,LAPACK_NUM_THREDS=1)
  
  B=1000          # 1000
  K=1000          # 1000
  error_K=0       #20 # extra K to run in case of errors
  alpha=.05
  
  xi_iter=1000             # for inspect method
  sd_interval=c(-500,500)  # for loclin method
  loclin_bootstraps=200
  loclin_M_div=1000

  n_vector=c(2000)             #  c(3000,2000,1000,500)
  p_vector=c(100)              #  c(10,100)
  
  # Create dataframe scenario 1
  dgp_vector=c('IID','IIDT','LS','LST','GS','PS','PLS','GST','PST','PLST')
  
  experiment_df=expand.grid(dgp=dgp_vector,
                            p=p_vector,
                            n=n_vector,
                            stringsAsFactors = FALSE)
  
  experiment_df$threshold_seed=as.numeric(rownames(experiment_df))*10000
  experiment_df$threshold_seed=1:nrow(experiment_df)
  rownames(experiment_df)=1:nrow(experiment_df)
  
  setwd(results_dir)
  if(!file.exists(function_name)){
    dir.create(file.path(results_dir,function_name))
  }
  
  setwd(file.path(results_dir,function_name))
  write.csv(experiment_df,file=paste(function_name,'-experiment_df.csv',sep=''))
  setwd(working_dir)
  
  # Determine which row of lrv_df to analyze
  if(job_num==999){
    # Do nothing, run over the whole of lrv_df
    experiment_df=experiment_df
  }else if(job_num==997){
    experiment_df=experiment_df[7:8,]
  }else{
    # only look at the lrv_df with the job_num you want
    experiment_df=experiment_df[job_num,]
  }
  
  for(x in 1:nrow(experiment_df)){
    n = experiment_df[x,'n']
    p = experiment_df[x,'p']
    dgp = experiment_df[x,'dgp']
    s_prime=s_prime_select(dgp,n,p)
    s=scales_rot(n,p)
    s=sparsify_scales(s[1],s[2],n,p)
    experiment_number=as.numeric(rownames(experiment_df[x,]))
    
    set.seed(experiment_df[x,'threshold_seed'])
    
    thresh_start_time=proc.time()
    max_thresh = compute.threshold(n,p,nrep=xi_iter)
    thresh_end_time=proc.time()
    
    thresh_compute_time=(thresh_end_time-thresh_start_time)[3]
    
    cp_method_vec=c('INSPECT','DBLCUSUM','LOCLIN','AJDN')

    for(cp_method_i in 1:length(cp_method_vec)){
      cl <- parallel::makeCluster(ncores,outfile="")
      doParallel::registerDoParallel(cl)
      
      cp_method=cp_method_vec[cp_method_i]
      
      simulation_results=foreach(i= 1:(K+error_K), 
                                 .combine = 'rbind',
                                 .packages = c("Matrix",'doParallel','foreach','plyr',
                                               'InspectChangepoint','hdbinseg','KernSmooth'),
                                 .errorhandling='remove')%dopar%{
                                   # Load functions
                                   setwd(working_dir)
                                   source('AJDNHelperFunctions.R')
                                   source('LOCLINHelper.R')
                                   
                                   # Set a seed
                                   set.seed(1000*p+1000*n+i+strtoi(dgp,36L)+1000)
                                   
                                   results_vec=rep(0,4)
                                  
                                   # Create matrix to do changepoint detection on, if throws error (rare, try again)
                                   x_matrix = generate_x_matrix(n,p,dgp,s)
                                   auto_bandwidth=dpill(1:n,x_matrix[1,])
                                   auto_bandwidth=min(max(s),auto_bandwidth/n)
                                   
                                   # Here for various methods we calculate the estimated changepoints, each
                                   # variable XYZ_cp_located is a vector of where the changepoints have been located
                                   # note that if we do not want to run one method we can set XZY_cp_located=numeric(0)
                                   
                                   # Create a vector to keep track of compute times
                                   compute_times=rep(0,4)
                                   
                                   if(cp_method=='INSPECT'){
                                     start_time=proc.time() 
                                     sparse_cp_located = inspect(x=x_matrix,threshold=max_thresh)$changepoints[,1]
                                     end_time=proc.time()
                                     compute_times[1]=(end_time-start_time)[3]+thresh_compute_time 
                                     if(length(sparse_cp_located)>0){
                                       results_vec[1]=1
                                     }
                                   }else if(cp_method=='DBLCUSUM'){
                                     start_time=proc.time()
                                     dblcusum_cp_located = dcbs.alg(x_matrix,
                                                                    cp.type=1,     # look for CP in mean
                                                                    phi=-1,        # section 4.1 of paper
                                                                    # phi=0 good for sparse cp
                                                                    # phi=.5 optimal in certain scenario
                                                                    temporal=TRUE, # use LR variance to normalize
                                                                    q=alpha,       # quantile of bootstrap to use as threshold 
                                                                    B=B,           # number of bootstraps to use
                                                                    do.parallel = 0)           
                                     dblcusum_cp_located = as.numeric(dblcusum_cp_located$ecp)
                                     end_time=proc.time()  
                                     compute_times[2]=(end_time-start_time)[3]
                                     
                                     if(length(dblcusum_cp_located)>0){
                                       results_vec[2]=1
                                     }
                                   }else if(cp_method=='AJDN'){
                                     start_time=proc.time()
                                     ajdn_cp_located=ajdn_detect_jumps(x_matrix,s,s_prime,B,alpha)
                                     end_time=proc.time()
                                     compute_times[4]=(end_time-start_time)[3]
                                     
                                     if(nrow(ajdn_cp_located)>0){
                                       results_vec[4]=1
                                     }
                                   }else if(cp_method=='LOCLIN'){
                                     
                                     
                                     # Here we need to break up the time series so that this runs in an adequate
                                     # amount of time, here we will target the size of p*(n/M)~2500, which will
                                     # take this about 1 minute to compute
                                     # Note that in some simulations this M led to problems (I believe linked to too many)
                                     # eigenvalues being close to 0 of the Q matrix, therefore will try this M and if it doesn't
                                     # work will try a different M with more observations per block
                                     M=round(p*n/loclin_M_div)
                                     
                                     start_time=proc.time()
                                     loclin_cp_located=try(loclin_cp(x_matrix,auto_bandwidth,sd_interval,alpha,loclin_bootstraps,M),silent=TRUE) 
                                     end_time=proc.time()
                                     compute_times[3]=(end_time-start_time)[3]
                                     
                                     if(class(loclin_cp_located)[1]=='try-error'){
                                       results_vec[3]=999 
                                     }else{
                                       if(length(loclin_cp_located)>0){
                                         results_vec[3]=1
                                       }
                                     }
                                     
                                   }
                                   
                                   print(paste(cp_method,i))
                                   print(Sys.time())

                                   c(results_vec,compute_times)
                                 }
      
      parallel::stopCluster(cl)
      
      setwd(file.path(results_dir,function_name))
      if(!file.exists('longformresults')){
        dir.create(file.path(results_dir,function_name,'longformresults'))
      }  
      
      setwd(file.path(results_dir,function_name,'longformresults'))
      write.csv(simulation_results,paste(sprintf("%03d",experiment_number),cp_method,'-longformresults.csv',sep=''))
      
    }
    
  }
  
}


