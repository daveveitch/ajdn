##### Testing nonstationarity #####
check_for_nonstationarity<-function(){
  # Implementation of tests of 'Change poitn analysis of correlation in nonstationary time series (Dette, Wu, Zhou 2019)
  # as well as heteroscedasticity and autocorrelation robust structural change detection (Zhou 2013)
  
  #### HELPER FUNCTIONS CORRELATION CP #### 
  local_linear_mu_estimate<-function(data_ts,t_vector,b_n,n){
    # This function produces local linear estimates of the trend
    # of a time series using the Epanechnikov kernel
    # Come up with local linear estimates of mean
    # INPUT
    # data_ts              - a vector of time series observations
    # t_vector             - a vector of times (i/n) for each observation
    # b_n                  - a bandwidth (between 0 and 1)
    # n                    - number of observations in the series
    # OUTPUT
    # local_linear_mu      - an estimate of the local linear
    # local_linear_mu_matrix - Q matrix used in generalized cross validation
    
    local_linear_mu=rep(0,length(t_vector))
    local_linear_mu_matrix=matrix(data=0,nrow=n,ncol=n)
    
    for(i in 1:length(t_vector)){
      t=i/n
      # A vector of of which observations should be included/excluded
      include_exclude_vector=(abs(t_vector-t)/b_n)<=1
      t_i_minus_t=t_vector[include_exclude_vector]-t
      
      X=matrix(data=c(rep(1,sum(include_exclude_vector)),t_i_minus_t),ncol=2)
      W=diag((3/4)*(1-(t_i_minus_t/b_n)**2))
      Y=data_ts[include_exclude_vector]
      
      local_linear_mu_matrix[i,include_exclude_vector]=(solve(t(X)%*%W%*%X)%*%t(X)%*%W)[1,]
      local_linear_mu[i]=local_linear_mu_matrix[i,include_exclude_vector]%*%Y
      
      # if(i%%100==0){print(i)}
    }
    
    return(list(local_linear_mu,local_linear_mu_matrix))
  }
  
  calc_M_i<-function(data_ts,local_linear_mu,L){
    # This function calculates M(i) for all values of i
    # INPUT
    # data_ts           - time series
    # local_linear_mu   - local linear estimate of mean
    # L                 - hyperparameter associated with a window size
    n=length(data_ts)
    
    M_i=rep(0,n)
    
    estimated_residuals_sq=(data_ts-local_linear_mu)**2
    
    for(i in L:(n-L+1)){
      M_i[i]=(sum(estimated_residuals_sq[(i-L+1):i])-sum(estimated_residuals_sq[(i):(i+L-1)]))/L
    }
    
    return(M_i)
  }
  
  local_linear_var_estimate<-function(e_hat_sq,t_vector,c_n,n,k,allow_for_cp){
    # This function produces local linear estimates of the variance
    # of a time series using the Epanechnikov kernel
    # INPUT
    # e_hat_sq             - a vector of estimated squared residuals
    # t_vector             - a vector of times (i/n) for each observation
    # c_n                  - a bandwidth (between 0 and 1)
    # n                    - number of observations in the series
    # k                    - location of variance changepoint
    # allow_for_cp         - TRUE/FALSE whether we allow for changepoint in variance
    # OUTPUT
    # local_linear_var        - an estimate of the local linear variance
    # local_linear_var_matrix - Q matrix used in generalized cross validation
    
    local_linear_var=rep(0,length(t_vector))
    local_linear_var_matrix=matrix(data=0,nrow=n,ncol=n)
    
    if(allow_for_cp){
      for(i in 1:length(t_vector)){
        t=i/n
        
        # A vector of which observations should be included/excluded
        # must account for which side of the variance changepoint we are on
        if(i<=k){
          include_exclude_vector=(((abs(t_vector-t)/c_n)<=1)&(round(t_vector,10)<=round(k/n,10)))
        }else{
          include_exclude_vector=(((abs(t_vector-t)/c_n)<=1)&(round(t_vector,10)>round(k/n,10)))
        }
        
        t_i_minus_t=t_vector[include_exclude_vector]-t
        
        X=matrix(data=c(rep(1,sum(include_exclude_vector)),t_i_minus_t),ncol=2)
        W=diag((3/4)*(1-(t_i_minus_t/c_n)**2))
        Y=e_hat_sq[include_exclude_vector]
        
        local_linear_var_matrix[i,include_exclude_vector]=(solve(t(X)%*%W%*%X)%*%t(X)%*%W)[1,]
        local_linear_var[i]=local_linear_var_matrix[i,include_exclude_vector]%*%Y
        
      } 
    }else{
      for(i in 1:length(t_vector)){
        t=i/n
        
        # A vector of which observations should be included/excluded, no changepoint in variance
        include_exclude_vector=(abs(t_vector-t)/c_n)<=1
        
        t_i_minus_t=t_vector[include_exclude_vector]-t
        
        X=matrix(data=c(rep(1,sum(include_exclude_vector)),t_i_minus_t),ncol=2)
        W=diag((3/4)*(1-(t_i_minus_t/c_n)**2))
        Y=e_hat_sq[include_exclude_vector]
        
        local_linear_var_matrix[i,include_exclude_vector]=(solve(t(X)%*%W%*%X)%*%t(X)%*%W)[1,]
        local_linear_var[i]=local_linear_var_matrix[i,include_exclude_vector]%*%Y
        
      } 
    }
    
    
    return(list(local_linear_var,local_linear_var_matrix))
    
  }
  
  calculate_S_matrix<-function(data_ts,mu_estimate,var_estimate,r_vector){
    # This function calulates the S_i CUSUM statistics thata are used for the test statistic
    # INPUT
    # data_ts        - time series of interest
    # mu_estimate    - estimate of the time varying mean
    # var_estimate   - estimate of the time varying variance
    # r_vector       - a vector of the lags of interest
    
    # OUTPUT
    # S_matrix       -  matrix of cusum stats for each of the specified lags
    
    n=length(data_ts)
    
    # Setup matrix of values of S for different r's
    S_matrix=matrix(data=0,nrow=length(r_vector),ncol=n)
    
    # Estimate residuals
    residual_vector=data_ts-mu_estimate
    
    for(j in 1:length(r_vector)){
      r=r_vector[j]
      
      S_matrix[j,1]=residual_vector[1]*residual_vector[1+r]/var_estimate[1]
      
      # Incrementally calculate S_i for each i
      for(i in 2:(n-r)){
        S_matrix[j,i]=S_matrix[j,i-1]+residual_vector[i]*residual_vector[i+r]/var_estimate[i]
      }
      
      # For last few observations of S_i, make it equal to the last value of S_i
      if(r>0){
        for(k in (n-r+1):n){
          S_matrix[j,k]=S_matrix[j,i]
        }
      }
      
    }  
    
    return(S_matrix) 
  }
  
  calculate_T_n<-function(S_matrix){
    # This function calculates T_n from the S_i matrix
    # INPUT
    # S_matrix - matrix of CUSUM stats
    # OUTPUT
    # T_n      - test statistic
    # T_vector - vector of test statistics we take maximum over to get T_n
    # T_n_time - time where maximum occurs
    
    n=dim(S_matrix)[2]
    
    T_matrix=S_matrix
    T_vector=rep(0,n)
    
    for(i in 1:nrow(S_matrix)){
      T_matrix[i,]=S_matrix[i,]-seq(1,n)/n*S_matrix[i,n]
    }
    
    for(i in 1:n){
      T_vector[i]=sqrt(sum(T_matrix[,i]**2))
    }
    
    T_n=max(T_vector)
    T_n_time=which.max(T_vector)
    
    return(list(T_n,T_n_time,T_vector))
  }
  
  S_j_m_matrix_and_S_n<-function(e_hat,local_linear_var,m,r_vector){
    # This function calculates both the S_j_m matrix and S_n for a 
    # given set of parameters
    # INPUT
    # e_hat            - estimates of the residuals of the time series
    # local_linear_var - estimates of the variance of the time series
    # r_vector         - vector of autocorrelations to test
    # m                - bootstrap window size
    # OUTPUT
    # S_j_m_S_n        - a list where first entry is S_j_m matrix and second is S_n
    
    S_j_m_matrix = matrix(data=0,ncol=n,nrow=length(r_vector))
    
    # Matrix of S_j_m-m/nS_n values
    CUSUM_matrix=matrix(data=0,ncol=n,nrow=length(r_vector))
    
    # Last column we can compute (either because of lag we are looking at, or m)
    last_col=max(c(m,r_vector+m))
    
    for(j in 1:(n-last_col-1)){
      for(k in 1:length(r_vector)){
        S_j_m_matrix[k,j]=sum(e_hat[j:(j+m-1)]*e_hat[(j+r_vector[k]):(j+r_vector[k]+m-1)]/local_linear_var[j:(j+m-1)])
      }    
    }
    for(j in (n-last_col-1+1):n){
      for(k in 1:length(r_vector)){
        S_j_m_matrix[k,j]=S_j_m_matrix[k,n-last_col-1]
      }  
    }
    
    # Calculate S_j_n vector
    S_j_n=rep(0,length(r_vector))
    for(k in 1:length(r_vector)){
      S_j_n[k]=sum(e_hat[1:(n-r_vector[k])]*e_hat[(r_vector[k]+1):n]/local_linear_var[1:(n-r_vector[k])])
    }
    
    CUSUM_matrix=S_j_m_matrix-(m/n)*S_j_n
    
    return(list(S_j_m_matrix,S_j_n,CUSUM_matrix))
    
  }
  
  mv_method_m<-function(e_hat,local_linear_var,r_vector,m_vector,mv_window){
    # This function uses a minimum volatility method to choose the window size
    # of the bootstrap
    # INPUT
    # e_hat            - estimates of the residuals of the time series
    # local_linear_var - estimates of the variance of the time series
    # r_vector         - vector of autocorrelations to test
    # m_vector         - vector of bootstrap window sizes to test
    # mv_window        - window to take MV variance over
    
    # OUTPUT
    # mv_m             - a mv estimate of the bootstrap size
    
    # Create matrix for S_j_m
    n=length(e_hat)
    
    
    # This is a vector which contains the statistic we are caclulating which
    # goes into the MV calculation to pick an appropriate m
    mv_amounts=rep(0,length(m_vector))
    mv_var=rep(0,length(m_vector))
    count=0
    
    for(m in m_vector){
      count=count+1
      
      S_j_m_S_n=S_j_m_matrix_and_S_n(e_hat,local_linear_var,m,r_vector)
      
      S_j_m_matrix=S_j_m_S_n[[1]]
      S_j_n=S_j_m_S_n[[2]]
      CUSUM_matrix=S_j_m_S_n[[3]]
      
      mv_amounts[count]=sum((CUSUM_matrix**2)/(m*(n-m+1)))
    }
    
    # Calculate variance of MV amount
    for(i in 1:length(mv_var)){
      mv_var[i]=var(mv_amounts[(max(1,i-mv_window)):(min(length(mv_var),i+mv_window))])
    }
    
    return(m_vector[which.min(mv_var)])
    
  }
  
  calculate_critical_value<-function(e_hat,local_linear_var,m,r_vector,
                                     B, alpha, initial_seed){
    # This function takes in the S_matrix, and then roots a bootstrap procedure
    # to calculate the critiacl value
    
    # INPUT
    # e_hat            - estimates of the residuals of the time series
    # local_linear_var - estimates of the variance of the time series
    # r_vector         - vector of autocorrelations to test
    # m                - bootstrap window size
    # B                - number of bootstraps
    # alpha            - significance level
    # initial_seed     - initial_seed to use
    
    # OUTPUT
    # critical_value_list - [[1]] critical value fo the test
    #                       [[2]] bootstrap values
    n=length(e_hat)
    
    # First step to calculate the CUSUM matrix which is used across all bootstraps
    CUSUM_matrix=S_j_m_matrix_and_S_n(e_hat,local_linear_var,m,r_vector)[[3]]
    
    bootstrap_statistics=rep(0,B)
    
    # Conduct the bootstrap
    for(b in 1:B){
      set.seed(initial_seed+b)
      
      # generate normals
      bootstrap_normals=rnorm(length(e_hat))
      bootstrapped_CUSUM_matrix=sweep(CUSUM_matrix,MARGIN=2,bootstrap_normals,'*')
      
      # Calculate CUSUM statistics of phi 
      
      phi_matrix=matrix(data=0,nrow=length(r_vector),ncol=(n-m+1))
      
      for(i in 1:(n-m+1)){
        phi_matrix[,i]=rowSums(bootstrapped_CUSUM_matrix[,1:i,drop=FALSE])/(sqrt(m*(n-m+1)))
      }
      
      phi_CUSUM_matrix=matrix(data=0,nrow=length(r_vector),ncol=(n-m+1))
      
      for(i in 1:(n-m+1)){
        phi_CUSUM_matrix[,i]=phi_matrix[,i]-(i/(n-m+1))*phi_matrix[,n-m+1]
      }
      
      # Calculate the norm of each column
      iteration_norms=rep(0,n-m+1)
      for(i in 1:(n-m+1)){
        iteration_norms[i]=sqrt(sum(phi_CUSUM_matrix[,i]**2))
      }
      
      # Record bootstrap statistic
      bootstrap_statistics[b]=max(iteration_norms[(m+1):(n-m+1)])
    }
    
    return(list(quantile(bootstrap_statistics,1-alpha),bootstrap_statistics))
    
  }
  
  GCV_b<-function(data_ts,b_n_to_test,silent){
    # This function tests a variety of bandwidths and returns the best one according to 
    # Generalized cross validation for the mean
    # INPUT
    # data_ts          - the time series of observations
    # b_n_to_test      - a vector of bandwidths to test
    # silent           - print b_n?
    
    n=length(data_ts)
    t_vector=1:length(data_ts)/n
    
    # Create a vector to store GCV values
    gcv_stat=rep(0,length(b_n_to_test))
    
    for(i in 1:length(b_n_to_test)){
      b_n=b_n_to_test[i]
      
      local_linear_mu=local_linear_mu_estimate(data_ts,t_vector,b_n,n)
      
      gcv_stat[i]=(sum(abs(data_ts-local_linear_mu[[1]]))/n)/(1-sum(diag(local_linear_mu[[2]]))/n)**2
      if(silent==FALSE){print(b_n)}
    }
    
    argmin_b_n=b_n_to_test[which.min(gcv_stat)]
    
    return(argmin_b_n)
  }
  
  GCV_c<-function(e_hat_sq,c_n_to_test,k,allow_for_cp,silent){
    # This function tests a variety of bandwidths and returns the best one according to 
    # Generalized cross validation for the variance
    # INPUT
    # e_hat_sq          - an estimate of residuals based on data and local linear mean
    # c_n_to_test       - a vector of bandwidths to test
    # k                 - estimate of changepoint in the variance
    # allow_for_cp      - whether to allow variance to undergo a changepoint
    # silent            - whether to print as conducting GCV
    
    n=length(e_hat_sq)
    t_vector=1:length(e_hat_sq)/n
    
    # Create a vector to store GCV values
    gcv_stat=rep(0,length(c_n_to_test))
    
    for(i in 1:length(c_n_to_test)){
      c_n=c_n_to_test[i]
      
      local_linear_var=local_linear_var_estimate(e_hat_sq,t_vector,c_n,n,k,allow_for_cp)
      
      gcv_stat[i]=(sum(abs(e_hat_sq-local_linear_var[[1]]))/n)/(1-sum(diag(local_linear_var[[2]]))/n)**2
      if(silent==FALSE){print(c_n)}
    }
    
    argmin_c_n=c_n_to_test[which.min(gcv_stat)]
    
    return(argmin_c_n)
  }
  
